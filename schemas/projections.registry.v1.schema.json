{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "eco-ontology/projections.registry.v1",
  "title": "EcoOntologyRegistryProjectionV1",
  "description": "Draft formal schema for generated graph and KB registry projection artifacts.",
  "oneOf": [
    {
      "$ref": "#/definitions/graph_registry_projection"
    },
    {
      "$ref": "#/definitions/kb_registry_projection"
    }
  ],
  "definitions": {
    "graph_registry_projection": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_by",
        "registries",
        "ownership_boundary"
      ],
      "properties": {
        "schema_version": {
          "const": "eco-ontology.projection.graph.registry.v1"
        },
        "generated_by": {
          "$ref": "#/definitions/generated_by"
        },
        "registries": {
          "$ref": "#/definitions/graph_registries"
        },
        "ownership_boundary": {
          "$ref": "#/definitions/graph_ownership_boundary"
        }
      },
      "additionalProperties": false
    },
    "kb_registry_projection": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_by",
        "registries",
        "ownership_boundary"
      ],
      "properties": {
        "schema_version": {
          "const": "eco-ontology.projection.kb.registry.v1"
        },
        "generated_by": {
          "$ref": "#/definitions/generated_by"
        },
        "registries": {
          "$ref": "#/definitions/kb_registries"
        },
        "ownership_boundary": {
          "$ref": "#/definitions/kb_ownership_boundary"
        }
      },
      "additionalProperties": false
    },
    "graph_registries": {
      "type": "object",
      "required": [
        "risk_domains",
        "issue_types",
        "observed_signals",
        "entity_anchors",
        "legal_basis_ref"
      ],
      "properties": {
        "risk_domains": {
          "$ref": "#/definitions/registry_entries"
        },
        "issue_types": {
          "$ref": "#/definitions/registry_entries"
        },
        "observed_signals": {
          "$ref": "#/definitions/registry_entries"
        },
        "entity_anchors": {
          "$ref": "#/definitions/registry_entries"
        },
        "legal_basis_ref": {
          "$ref": "#/definitions/registry_entries"
        }
      },
      "additionalProperties": false
    },
    "kb_registries": {
      "type": "object",
      "required": [
        "issue_types",
        "observed_signals",
        "entity_anchors",
        "legal_basis_ref"
      ],
      "properties": {
        "issue_types": {
          "$ref": "#/definitions/registry_entries"
        },
        "observed_signals": {
          "$ref": "#/definitions/registry_entries"
        },
        "entity_anchors": {
          "$ref": "#/definitions/registry_entries"
        },
        "legal_basis_ref": {
          "$ref": "#/definitions/registry_entries"
        }
      },
      "additionalProperties": false
    },
    "registry_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/registry_entry"
      }
    },
    "registry_entry": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "description",
        "owner",
        "status",
        "deprecated"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "display_name_zh": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 60 }
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "enum": [
            "eco-ontology",
            "EcoCheck",
            "eco-execution-graph",
            "eco-semantic-knowledge-base"
          ]
        },
        "status": {
          "enum": ["active", "candidate", "deprecated"]
        },
        "deprecated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "graph_ownership_boundary": {
      "type": "object",
      "required": ["graph_owns", "ontology_owns"],
      "properties": {
        "graph_owns": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["assembly", "tiering", "review", "exports"]
          }
        },
        "ontology_owns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": ["shared_ids", "schema_refs", "release_hashes"]
          }
        }
      },
      "additionalProperties": false
    },
    "kb_ownership_boundary": {
      "type": "object",
      "required": ["kb_owns", "ontology_owns"],
      "properties": {
        "kb_owns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": ["approved_atoms", "source_manifests", "knowledge_products"]
          }
        },
        "ontology_owns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": ["reference_shapes", "manifest_schema", "projection_hashes"]
          }
        }
      },
      "additionalProperties": false
    },
    "generated_by": {
      "type": "object",
      "required": [
        "generator",
        "generator_version",
        "ontology_version",
        "source_sha256"
      ],
      "properties": {
        "generator": {
          "const": "scripts/generate-projections.mjs"
        },
        "generator_version": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "ontology_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
        },
        "source_sha256": {
          "$ref": "#/definitions/source_sha256"
        }
      },
      "additionalProperties": false
    },
    "source_sha256": {
      "type": "object",
      "required": [
        "registries/entity_anchors.v1.json",
        "registries/issue_types.v1.json",
        "registries/legal_basis_ref.v1.json",
        "registries/observed_signals.v1.json",
        "registries/risk_domains.v1.json",
        "schemas/kb_product_manifest.v1.schema.json",
        "schemas/ontology_registry.v1.schema.json",
        "schemas/profile_gap_confirmed.v1.schema.json",
        "schemas/semantic_event.v2.schema.json"
      ],
      "properties": {
        "registries/entity_anchors.v1.json": {
          "$ref": "#/definitions/sha256"
        },
        "registries/issue_types.v1.json": {
          "$ref": "#/definitions/sha256"
        },
        "registries/legal_basis_ref.v1.json": {
          "$ref": "#/definitions/sha256"
        },
        "registries/observed_signals.v1.json": {
          "$ref": "#/definitions/sha256"
        },
        "registries/risk_domains.v1.json": {
          "$ref": "#/definitions/sha256"
        },
        "schemas/kb_product_manifest.v1.schema.json": {
          "$ref": "#/definitions/sha256"
        },
        "schemas/ontology_registry.v1.schema.json": {
          "$ref": "#/definitions/sha256"
        },
        "schemas/profile_gap_confirmed.v1.schema.json": {
          "$ref": "#/definitions/sha256"
        },
        "schemas/semantic_event.v2.schema.json": {
          "$ref": "#/definitions/sha256"
        }
      },
      "additionalProperties": false
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
