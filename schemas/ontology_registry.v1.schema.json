{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "eco-ontology/ontology_registry.v1",
  "title": "EcoOntologyRegistryV1",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "ontology_version",
    "owner",
    "description",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "eco-ontology.registry.v1" },
    "registry_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.v[0-9]+$"
    },
    "ontology_version": { "type": "string" },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/registry_entry" }
    }
  },
  "definitions": {
    "registry_entry": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "description",
        "owner",
        "status",
        "deprecated"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        },
        "display_name": { "type": "string", "minLength": 1 },
        "display_name_zh": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "owner": {
          "enum": [
            "eco-ontology",
            "EcoCheck",
            "eco-execution-graph",
            "eco-semantic-knowledge-base"
          ]
        },
        "status": { "enum": ["active", "candidate", "deprecated"] },
        "deprecated": { "type": "boolean" },
        "superseded_by": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        },
        "sunset_after": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        },
        "review": {
          "type": "object",
          "required": ["reviewed_by", "reviewed_at", "status"],
          "properties": {
            "reviewed_by": { "type": "string", "minLength": 1 },
            "reviewed_at": {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
            },
            "status": {
              "enum": ["seed", "expert_reviewed", "authoritative"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
