{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "eco-ontology/legal_instrument.v1",
  "title": "EcoOntologyLegalInstrumentRegistryV1",
  "description": "Legal-instrument lifecycle registry. Stores citation metadata and lifecycle only (发文机关/文号/GB·HJ号/生效废止/替代关系), never full law or standard text.",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "ontology_version",
    "owner",
    "description",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "eco-ontology.legal_instrument.v1" },
    "registry_id": { "const": "legal_instruments.v1" },
    "ontology_version": { "type": "string" },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/instrument" }
    }
  },
  "definitions": {
    "date": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "instrument_id": {
      "type": "string",
      "pattern": "^li\\.[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "nullable_instrument_id": {
      "type": ["string", "null"],
      "pattern": "^li\\.[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "instrument": {
      "type": "object",
      "required": [
        "id",
        "instrument_type",
        "title_zh",
        "source_authority",
        "status",
        "effective_date",
        "repeal_date",
        "replaced_by",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/definitions/instrument_id" },
        "instrument_type": {
          "enum": [
            "law",
            "administrative_regulation",
            "department_rule",
            "local_regulation",
            "national_standard",
            "industry_standard",
            "local_standard",
            "catalog",
            "permit_scheme",
            "other"
          ]
        },
        "title_zh": { "type": "string", "minLength": 1, "maxLength": 200 },
        "title_en": { "type": "string", "maxLength": 300 },
        "source_authority": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "doc_number": { "type": ["string", "null"], "maxLength": 120 },
        "standard_code": { "type": ["string", "null"], "maxLength": 60 },
        "status": {
          "enum": [
            "in_force",
            "not_yet_effective",
            "superseded",
            "repealed",
            "draft"
          ]
        },
        "effective_date": { "$ref": "#/definitions/date" },
        "repeal_date": { "$ref": "#/definitions/date" },
        "replaced_by": { "$ref": "#/definitions/nullable_instrument_id" },
        "supersedes": {
          "type": "array",
          "items": { "$ref": "#/definitions/instrument_id" }
        },
        "clause_refs": {
          "type": "array",
          "items": { "$ref": "#/definitions/clause_ref" }
        },
        "official_source": { "$ref": "#/definitions/official_source" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "review": { "$ref": "#/definitions/review" }
      },
      "additionalProperties": false
    },
    "clause_ref": {
      "type": "object",
      "required": ["clause_id"],
      "properties": {
        "clause_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "description": "Citation pointer only, e.g. 第二十四条 or 4.2.1 — never clause text."
        },
        "label_zh": {
          "type": "string",
          "maxLength": 120,
          "description": "Short human label, never full clause text."
        }
      },
      "additionalProperties": false
    },
    "official_source": {
      "type": "object",
      "required": ["url", "retrieved_at"],
      "properties": {
        "url": { "type": "string", "minLength": 1, "maxLength": 300 },
        "retrieved_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$",
          "description": "Fingerprint over normalized citation metadata or the official PDF, never stored full text."
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": ["reviewed_by", "reviewed_at", "status"],
      "properties": {
        "reviewed_by": { "type": "string", "minLength": 1 },
        "reviewed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": { "enum": ["seed", "expert_reviewed", "authoritative"] },
        "method": {
          "enum": [
            "engineer_seed",
            "web_verified",
            "legal_counsel",
            "government_lineage"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
