  "checks": {
    "blocking_ready": [
      {
        "check_id": "ECO-ONTO-SCHEMA-COMPILE",
        "owner": "eco-ontology",
        "applies_to": ["schemas/*.schema.json"],
        "reason": "All ontology JSON Schemas must declare Draft-07 and compile with Ajv v6."
      },
      {
        "check_id": "ECO-ONTO-REGISTRY-SHAPE",
        "owner": "eco-ontology",
        "applies_to": ["registries/*.v1.json"],
        "reason": "Registry files validate against ontology_registry.v1 and keep unique ids."
      },
      {
        "check_id": "ECO-ONTO-PROJECTION-SHAPE",
        "owner": "eco-ontology",
        "applies_to": ["dist/projections/*.json"],
        "reason": "Generated projection artifacts validate against their projections.*.v1 schemas."
      },
      {
        "check_id": "CROSS-002-PROJECTION-HASH",
        "owner": "eco-ontology",
        "applies_to": [
          "contracts/consumer-compatibility-matrix.v1.json",
          "dist/projections/*.json"
        ],
        "reason": "Consumer projection artifacts exist and match pinned sha256 values."
      },
      {
        "check_id": "ONTOLOGY-SAFE-SAMPLES",
        "owner": "eco-ontology",
        "applies_to": [
          "schemas/semantic_event.v2.schema.json",
          "schemas/profile_gap_confirmed.v1.schema.json"
        ],
        "reason": "Synthetic safe samples validate without reading private enterprise data."
      }
    ],
    "consumer_evidence": [
      {
        "check_id": "GRAPH-REPORT-ONLY-CLEAN",
        "owner": "eco-execution-graph",
        "applies_to": [
          "E:/eco-execution-graph/reports/ontology-contract-report-only-validation.json"
        ],
        "reason": "Graph evidence freshness and summary status stay in the graph owner lane."
      },
      {
        "check_id": "ECOCHECK-VALID-FIXTURES",
        "owner": "EcoCheck",
        "applies_to": [
          "E:/EcoCheck/docs/validation/semantic-event-report-only.latest.json",
          "E:/EcoCheck/docs/validation/semantic-event-blocking.latest.json"
        ],
        "reason": "EcoCheck fixture evidence belongs to EcoCheck and must not silently change scoring semantics."
      }
    ],
    "external_gates": [
      {
        "check_id": "TENCENT-RAG-REAL-SMOKE",
        "owner": "eco-semantic-knowledge-base",
        "applies_to": ["live Tencent RAG environment"],
        "reason": "Live RAG retrieval requires external credentials and remains outside the local ontology gate."
      },
      {
        "check_id": "CLOUDBASE-SCAN-REAL-SMOKE",
        "owner": "EcoCheck",
        "applies_to": ["live CloudBase and WeCom scan environment"],
        "reason": "Live CloudBase storage and scan evidence remains outside this repository."
      },
      {
        "check_id": "GOVERNMENT-LINEAGE-REAL-IMPORT",
        "owner": "eco-semantic-knowledge-base",
        "applies_to": ["real government lineage import"],
        "reason": "Real lineage import evidence is owned by the KB lane."
      },
      {
        "check_id": "ECOCHECK-AGGREGATE-ETO-BLIND-REVIEW",
        "owner": "EcoCheck",
        "applies_to": ["real aggregate and ETO blind review"],
        "reason": "Human review evidence is EcoCheck-owned and cannot be manufactured by ontology validation."
      }
    ]
  }
